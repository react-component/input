{
  "name": "@rc-component/input",
  "version": "1.3.1",
  "description": "React input component",
  "keywords": [
    "react",
    "react-component",
    "react-input",
    "input",
    "antd",
    "ant-design"
  ],
  "main": "./lib/index",
  "module": "./es/index",
  "files": [
    "assets/*.css",
    "assets/*.less",
    "es",
    "lib"
  ],
  "homepage": "https://react-component.github.io/input",
  "repository": {
    "type": "git",
    "url": "https://github.com/react-component/input.git"
  },
  "bugs": {
    "url": "https://github.com/react-component/input/issues"
  },
  "license": "MIT",
  "scripts": {
    "build": "npm run docs:build",
    "start": "dumi dev",
    "docs:build": "dumi build",
    "docs:deploy": "gh-pages -d docs-dist",
    "compile": "father build && lessc assets/index.less assets/index.css",
    "gh-pages": "cross-env GH_PAGES=1 npm run docs:build && npm run docs:deploy",
    "prepublishOnly": "npm run compile && rc-np",
    "postpublish": "npm run gh-pages",
    "lint": "eslint src/ --ext .ts,.tsx,.jsx,.js,.md",
    "prettier": "prettier --write --ignore-unknown .",
    "test": "rc-test",
    "tsc": "tsc --noEmit",
    "coverage": "rc-test --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@rc-component/resize-observer": "^1.1.1",
    "@rc-component/util": "^1.11.1",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/compat": "^2.1.0",
    "@rc-component/father-plugin": "^2.2.0",
    "@rc-component/np": "^1.0.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "dumi": "^2.4.38",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "father": "^4.6.24",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "less": "^4.6.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "rc-test": "^7.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.62.1"
  },
  "peerDependencies": {
    "react": ">=16.0.0",
    "react-dom": ">=16.0.0"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "cnpm": {
    "mode": "npm"
  },
  "tnpm": {
    "mode": "npm"
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./es/index.d.ts"
}
